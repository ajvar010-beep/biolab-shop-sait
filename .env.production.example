# ==========================================
# Biolab — пример .env для продакшена (Render.com / VPS)
# SQLite база данных — бесплатно и просто!
# ==========================================

# SQLite (хранится в файле data/biolab.db)
SQLITE_DB_PATH=./data/biolab.db

# JWT — сгенерируйте свой:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ЗАМЕНИТЕ_НА_СВОЙ_СЛУЧАЙНЫЙ_СЕКРЕТ_МИНИМУМ_32_СИМВОЛА
JWT_EXPIRES_IN=24h

# Email (для уведомлений). Yandex рекомендуется для РФ, либо Gmail App Password.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USER=your-email@yandex.ru
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@yandex.ru

# Server
PORT=10000
NODE_ENV=production

# CORS — реальный домен фронта (через запятую если несколько)
ALLOWED_ORIGINS=https://biolab-shop.onrender.com

# Безопасность
BCRYPT_ROUNDS=12
ALLOW_REGISTRATION=false

# Базовый URL фронта (для писем со ссылками)
FRONTEND_URL=https://biolab-shop.onrender.com

# Доверие за прокси (Render, Heroku, Nginx и т.п.)
TRUST_PROXY=1

# Данные админа по умолчанию
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminDemo2026