# ==========================================
# Biolab — пример .env
# Скопируйте в .env и заполните своими значениями
# ==========================================

# ===== База данных =====
# ЛОКАЛЬНАЯ РАЗРАБОТКА: используется SQLite (better-sqlite3)
SQLITE_DB_PATH=./data/biolab.db

# PRODUCTION на Render: используется PostgreSQL
# Создайте PostgreSQL на Render Dashboard → New → PostgreSQL
# Скопируйте Internal Database URL сюда:
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== Хранилище файлов =====
# ==========================================
# local - локальное хранение (по умолчанию, для разработки)
# s3 - S3-совместимое хранилище (для продакшена)
STORAGE_TYPE=local

# S3-настройки (только если STORAGE_TYPE=s3)
# Пример для Selectel: https://selcomru.github.io/
S3_ENDPOINT=https://storage.selcdn.ru
S3_BUCKET=biolab-uploads
S3_REGION=ru-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=


# ==========================================
# Telegram-уведомления для админа
# ==========================================
# Создайте бота через @BotFather в Telegram
# Получите chat_id через @userinfobot или через API бота
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# JWT — сгенерируйте свой:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=замените_на_случайную_строку_минимум_32_символа
JWT_EXPIRES_IN=24h

# Email (для уведомлений о заказах). Yandex рекомендуется для РФ.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USER=your-email@yandex.ru
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@yandex.ru

# Server
PORT=3000
NODE_ENV=development

# CORS: список разрешённых origin'ов через запятую
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Безопасность
BCRYPT_ROUNDS=12
ALLOW_REGISTRATION=false

# Базовый URL фронта (для писем со ссылками на заказ)
FRONTEND_URL=http://localhost:3000

# Данные админа по умолчанию
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminDemo2026