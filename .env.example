# ==========================================
# Biolab — пример .env для локальной разработки
# Скопируйте в .env и заполните своими значениями
# ==========================================

# SQLite (не нужен внешний сервер!)
SQLITE_DB_PATH=./data/biolab.db

# JWT — сгенерируйте свой:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=замените_на_случайную_строку_минимум_32_символа
JWT_EXPIRES_IN=24h

# Email (для уведомлений о заказах). Yandex рекомендуется для РФ.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USER=your-email@yandex.ru
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@yandex.ru

# Server
PORT=3000
NODE_ENV=development

# CORS: список разрешённых origin'ов через запятую
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Безопасность
BCRYPT_ROUNDS=12
ALLOW_REGISTRATION=false

# Базовый URL фронта (для писем со ссылками на заказ)
FRONTEND_URL=http://localhost:3000

# Данные админа по умолчанию
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminDemo2026