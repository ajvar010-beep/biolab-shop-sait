# ==========================================
# Biolab — пример .env
# Скопируйте в .env и заполните своими значениями
# ==========================================

# ===== База данных =====
# ЛОКАЛЬНАЯ РАЗРАБОТКА: используется SQLite (better-sqlite3)
SQLITE_DB_PATH=./data/biolab.db

# PRODUCTION на Render: используется PostgreSQL
# Создайте PostgreSQL на Render Dashboard → New → PostgreSQL
# Скопируйте Internal Database URL сюда:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== Хранилище файлов =====
# local - локальное хранение (по умолчанию, для разработки)
# s3 - S3-совместимое хранилище (для продакшена)
STORAGE_TYPE=local

# S3-настройки (только если STORAGE_TYPE=s3)
S3_ENDPOINT=https://storage.selcdn.ru
S3_BUCKET=biolab-uploads
S3_REGION=ru-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ==========================================
# 🔴 КРИТИЧНО: JWT Secret
# ==========================================
# Сгенерируйте случайный ключ (минимум 32 символа):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ НИКОГДА не используйте dev-ключ на production!
# ⚠️ На Render добавьте JWT_SECRET в Environment Variables
JWT_SECRET=замените_на_случайную_строку_минимум_32_символа
JWT_EXPIRES_IN=24h

# ==========================================
# Telegram-уведомления для админа
# ==========================================
# 1. Создайте бота через @BotFather в Telegram → /newbot
# 2. Получите BOT_TOKEN (формат: 123456789:ABCdef...)
# 3. Узнайте свой chat_id: напишите @userinfobot → /start
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ==========================================
# hCaptcha — защита формы заказа от ботов
# ==========================================
# Регистрация: https://dashboard.hcaptcha.com/ (Welcome plan — бесплатно)
# После регистрации добавьте HCAPTCHA_SECRET в Render Environment
# HCAPTCHA_SITE_KEY=ваш_site_key
# HCAPTCHA_SECRET=ваш_secret_key

# ==========================================
# Email (опционально — для уведомлений о заказах)
# ==========================================
EMAIL_ENABLED=false
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USER=your-email@yandex.ru
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@yandex.ru

# ==========================================
# Server
# ==========================================
PORT=3000
NODE_ENV=development

# CORS: список разрешённых origin'ов через запятую
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Безопасность
BCRYPT_ROUNDS=12
ALLOW_REGISTRATION=false

# Базовый URL фронта
FRONTEND_URL=http://localhost:3000

# Данные админа по умолчанию (создаётся при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminDemo2026
